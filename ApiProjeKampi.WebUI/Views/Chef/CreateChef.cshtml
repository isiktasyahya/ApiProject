@model CreateChefDto
@{
    ViewData["Title"] = "CreateChef";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Şef Ekleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <label>Ad Soyad</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Görevi</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Görsel Url</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <label>Açıklaması</label>
                            <textarea type="text" asp-for="Description" class="form-control"></textarea>
                            <br />
                            <button type="submit" class="btn btn-primary">Şef Ekle</button>
                        </form>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>





