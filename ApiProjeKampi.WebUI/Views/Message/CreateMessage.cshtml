@model CreateMessageDto
@{
    ViewData["Title"] = "CreateMessage";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Mesaj Ekleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <label>Ad Soyad</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Email</label>
                            <input type="text" asp-for="Email" class="form-control" />
                            <br />
                            <label>Konu</label>
                            <input type="text" asp-for="Subject" class="form-control" />
                            <br />
                            <label>Mesaj Detayı</label>
                            <textarea type="text" asp-for="MessageDetail" class="form-control" style="height:200px !important;"></textarea>
                            <br />
                            <label>
                                <input type="radio" asp-for="IsRead" value="True" /> Aktif
                            </label>
                            &ensp;
                            <label>
                                <input type="radio" asp-for="IsRead" value="False" /> Pasif
                            </label>
                            
                            
                            <br />
                            <button type="submit" class="btn btn-primary">Kategori Ekle</button>
                        </form>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>





