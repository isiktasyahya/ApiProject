@{
    ViewData["Title"] = "CreateRecipeWithOpenAI";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Opan AI ile Yapay Zeka Destekli Yemek Tarifi Önerisi</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <label>Elinizdeki Kelimeler ve Anahtar Kelimeler</label>
                            <input type="text" name="prompt" class="form-control" />
                            <br />
                            <button type="submit" class="btn btn-primary">Tarif Önerisi Oluştur</button>
                        </form>
                        <br /><br />
                        @if (ViewBag.receipe != null)
                        {
                            <h5>OpenAI Gelen Yanıt</h5>
                            @Html.Raw(ViewBag.receipe.ToString());
                        }
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>