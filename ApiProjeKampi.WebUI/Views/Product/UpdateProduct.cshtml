@model GetProductByIdDto
@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Ürün Güncelleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <input type="hidden" asp-for="ProductId" />
                            <label>Ürün Adı Giriniz</label>
                            <input type="text" asp-for="ProductName" class="form-control" />
                            <br />
                            <label>Ürün Fiyatı Giriniz</label>
                            <input type="number" asp-for="Price" class="form-control" />
                            <br />
                            <label>Ürün Kategorisi Giriniz</label>
                            <select asp-for="CategoryId" class="form-control"
                                    asp-items="(IEnumerable<SelectListItem>)ViewBag.v">
                                <option value="">-- Kategori Seçiniz --</option>
                            </select>
                            <br />
                            <label>Ürün Görsel Yolu Giriniz</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <label>Ürün Açıklaması Giriniz</label>
                            <textarea rows="5" class="form-control" asp-for="ProductDescription"></textarea>
                            <br />


                            <button type="submit" class="btn btn-primary">Ürünü Güncelle</button>
                        </form>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>

